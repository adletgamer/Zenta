# ============================================================
# Zenta — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values
# cp .env.example .env

# ---- Database -----------------------------------------------
DATABASE_URL="postgresql://zenta_user:zenta_password@localhost:5432/zenta_db?schema=public"
# Used by Prisma migrations against managed Postgres providers such as Supabase.
# For Supabase, set this to the direct/session connection, not the transaction pooler.
DIRECT_URL="postgresql://zenta_user:zenta_password@localhost:5432/zenta_db?schema=public"

# ---- Application --------------------------------------------
APP_ENV="development"
PORT=3001

# ---- ZK Verification Mode -----------------------------------
# SIMULATED = local mock proof (default for development)
# STELLAR_REGISTRY_TESTNET = real Stellar testnet registry submission
VERIFICATION_MODE="STELLAR_REGISTRY_TESTNET"

# ---- Stellar Network ----------------------------------------
STELLAR_NETWORK="testnet"
STELLAR_RPC_URL="https://soroban-testnet.stellar.org"
STELLAR_CONTRACT_ID="CD3QVY4KKZPFSKHZFKUKKINNTJ7OQQVT73THQTDXEN4US4BK3DRQJRZO"
STELLAR_SECRET_KEY=""

# ---- ZK Circuit ---------------------------------------------
ZK_CIRCUIT_VERSION="payroll_v1"
ZK_WASM_PATH="./packages/zk/build/payroll_js/payroll.wasm"
ZK_ZKEY_PATH="./packages/zk/build/payroll_final.zkey"
ZK_VKEY_PATH="./packages/zk/build/verification_key.json"

# ---- Frontend -----------------------------------------------
# Leave empty on Vercel to use same-origin /api routes.
VITE_API_URL=""
