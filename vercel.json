{
  "buildCommand": "npm run db:generate && npm run build",
  "outputDirectory": "apps/web/dist",
  "functions": {
    "api/[...path].ts": {
      "includeFiles": "{packages/zk/build/**,node_modules/@stellar/**,node_modules/.pnpm/{@stellar+*,smol-toml@*,@noble+*,base32.js@*,bignumber.js@*,feaxios@*,eventsource@*,axios@*}/**}"
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/[...path].ts" },
    { "source": "/(.*)", "destination": "/" }
  ]
}
